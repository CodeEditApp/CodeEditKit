{"topicSections":[{"title":"Articles","identifiers":["doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/Commands","doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/CreatingProject","doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/LanguageServers","doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/Settings","doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/Snippets","doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/Themes","doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/ToolbarItems"],"generated":true},{"identifiers":["doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/EnvironmentPublisher"],"title":"Classes"},{"identifiers":["doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/CEEnvironmentKey","doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/CodeEditExtension","doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/EnvironmentPublisherObjc","doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/SettingsExtension","doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/Sidebar","doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/SidebarExtension","doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/XPCWrappable"],"title":"Protocols"},{"identifiers":["doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/CEEnvironment","doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/CEEnvironmentModifier","doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/CEOpenWindowEnvKey","doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/CodableColorArray","doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/Decoded","doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/Encoded","doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/Inspector","doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/Navigator","doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/ResolvedSidebar","doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/SidebarBuilder"],"title":"Structures"},{"title":"Functions","identifiers":["doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/print(_:separator:terminator:)"]},{"title":"Type Aliases","identifiers":["doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/XPCReply"]},{"title":"Enumerations","identifiers":["doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/Callbacks","doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/Entitlement","doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/ExtensionKind","doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/XPCError"]},{"identifiers":["doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/Swift","doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/SwiftUI"],"title":"Extended Modules"}],"hierarchy":{"paths":[[]]},"metadata":{"externalID":"CodeEditKit","role":"collection","modules":[{"name":"CodeEditKit"}],"title":"CodeEditKit","symbolKind":"module","roleHeading":"Framework"},"schemaVersion":{"patch":0,"minor":3,"major":0},"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","type":"heading","anchor":"Overview","level":2},{"inlineContent":[{"text":"Extensions are an essential part of CodeEdit. They can extend the languages CodeEdit supports, add custom actions and behaviors, and even provide custom views of certain data.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"CodeEditKit aims to provide an easy and straightforward API to implement these extensions, with modern technologies like Swift, SwiftUI and ExtensionKit."}],"type":"paragraph"},{"anchor":"Extension-Types","type":"heading","text":"Extension Types","level":3},{"type":"paragraph","inlineContent":[{"text":"There are lots of extension types you can use to extend the functionality of CodeEdit.","type":"text"}]},{"level":4,"text":"General Extensions","type":"heading","anchor":"General-Extensions"},{"items":[{"content":[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/Commands"},{"text":" (WIP)","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/Themes"},{"text":" (Not Started)","type":"text"}]}]}],"type":"unorderedList"},{"type":"heading","anchor":"Language-Extensions","text":"Language Extensions","level":4},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/Snippets","type":"reference"},{"type":"text","text":" (Not Started)"}]}]},{"content":[{"inlineContent":[{"identifier":"doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/LanguageServers","type":"reference","isActive":true},{"type":"text","text":" (WIP)"}],"type":"paragraph"}]}]},{"anchor":"UI-Extensions","level":4,"type":"heading","text":"UI Extensions"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/SidebarExtension","isActive":true},{"type":"text","text":" (Beta)"}]}]},{"content":[{"inlineContent":[{"isActive":true,"identifier":"doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/ToolbarItems","type":"reference"},{"text":" (WIP)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"identifier":"doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/Settings","isActive":true,"type":"reference"},{"type":"text","text":" (Beta)"}],"type":"paragraph"}]}]},{"text":"Getting Started","type":"heading","anchor":"Getting-Started","level":3},{"type":"paragraph","inlineContent":[{"text":"To setup your Xcode project, have a look at the ","type":"text"},{"type":"reference","identifier":"doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/CreatingProject","isActive":true},{"text":" section.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Next, have a look at "},{"identifier":"doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/CodeEditExtension","type":"reference","isActive":true},{"type":"text","text":". This is the base protocol that will define the main structure of your extension."},{"type":"text","text":" "},{"type":"text","text":"All extensions that you’ll add will extend (:p) this type."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Finally, try adding an extension to your newly created type. A good first recommendation is the ","type":"text"},{"type":"reference","identifier":"doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/Settings","isActive":true},{"type":"text","text":" extension, as you’ll likely need this later."}]},{"level":3,"type":"heading","text":"Development & Debugging","anchor":"Development--Debugging"},{"type":"paragraph","inlineContent":[{"text":"Developing extensions with ExtensionKit has a few annoyances:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Prints do not appear in the Xcode console. Instead, the debug information of CodeEdit (not the extension) is printed.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Modifying extension requires CodeEdit reload."}]}]},{"content":[{"inlineContent":[{"text":"An extension needs to be sandboxed.","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"CodeEdit tries to overcome these issues by offering a few solutions."}]},{"inlineContent":[{"text":"First, CodeEdit is able to capture log messages (which are also sent to Console.app). Therefore, CodeEdit provides a custom ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/print(_:separator:terminator:)"},{"type":"text","text":" function which works the same as Swift’s one, except it sends its input as an OSLog instead of printing it to stdout. With this change, you are able to view your extensions’ outputs in CodeEdit’s console. Later on, an extra toggle will be provided which will also print the changes to Xcode’s console."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Additionally, if you choose to use the powerful Logger system to debug, CodeEdit provides support for various log types and will color them accordingly."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Next, CodeEdit supports a way of hot reloading your extension. Instead of relaunching CodeEdit and the extension, only the extension is restarted, resulting in faster load times. To make use of this, build your extension instead of running it (⌘B instead of ⌘R). Note that this feature is still in beta and may behave unexpectedly."}]}]}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/codeeditkit"]}],"abstract":[{"text":"CodeEditKit is a dynamic library which is shared between CodeEdit and it’s extensions. It allows them to communicate with and understand one another.","type":"text"}],"identifier":{"url":"doc:\/\/CodeEditKit\/documentation\/CodeEditKit","interfaceLanguage":"swift"},"sections":[],"references":{"doc://CodeEditKit/documentation/CodeEditKit":{"role":"collection","url":"\/documentation\/codeeditkit","title":"CodeEditKit","kind":"symbol","type":"topic","identifier":"doc:\/\/CodeEditKit\/documentation\/CodeEditKit","abstract":[{"text":"CodeEditKit is a dynamic library which is shared between CodeEdit and it’s extensions. It allows them to communicate with and understand one another.","type":"text"}]},"doc://CodeEditKit/documentation/CodeEditKit/ResolvedSidebar":{"type":"topic","url":"\/documentation\/codeeditkit\/resolvedsidebar","identifier":"doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/ResolvedSidebar","role":"symbol","title":"ResolvedSidebar","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ResolvedSidebar"}],"kind":"symbol","abstract":[],"navigatorTitle":[{"kind":"identifier","text":"ResolvedSidebar"}]},"doc://CodeEditKit/documentation/CodeEditKit/Snippets":{"kind":"article","identifier":"doc:\/\/CodeEditKit\/documentation\/CodeEditKit\/Snippets","abstract":[],"url":"\/documentation\/codee